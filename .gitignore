# ---------------------------------------------------------------------------
# Keep your PRIVATE source documents OUT of the public website.
# These sit in the project folder for convenience but should NOT be published
# (cover letters, the LinkedIn export, multiple CV drafts, etc.).
#
# Only loose PDF/Word files in the project ROOT are ignored; anything inside
# subfolders (e.g. assets/) is still published normally.
# ---------------------------------------------------------------------------

# All PDFs / Word docs sitting in the project root (not in subfolders)
/*.pdf
/*.docx
/*.doc

# Claude Code / AI tooling — local config, agent notes, never publish
.claude/
CLAUDE.md
.cursor/
.aider*
.continue/

# Dependencies / build output (in case tooling is added later)
node_modules/
dist/
build/

# Environment / secrets
.env
.env.*

# OS / editor noise
Thumbs.db
.DS_Store
.vscode/
.idea/
*.log
